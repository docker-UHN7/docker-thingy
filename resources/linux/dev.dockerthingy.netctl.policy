<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">
<policyconfig>
  <vendor>Docker Project Explorer</vendor>

  <action id="dev.dockerthingy.netctl.manage">
    <description>Change container or network connectivity</description>
    <message>Authentication is required to change container or network connectivity</message>
    <!--
      auth_self (not auth_admin): this only needs to confirm it's really the
      logged-in user acting, not that they're a recognized "administrator" -
      auth_admin depends on distro-specific polkit rules wiring wheel/sudo
      group membership to admin identity, which isn't set up by default on
      every system (e.g. plain Arch) even for a user in that group.
    -->
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">/usr/local/libexec/docker-thingy/netctl</annotate>
  </action>
</policyconfig>
