{
  "name": "docker-thingy",
  "productName": "Docker Project Explorer",
  "version": "0.1.0",
  "description": "A sleek desktop explorer for Docker Compose projects, Dockerfiles, and runtime state.",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "dev": "node scripts/dev.js",
    "headless": "tsx src/headless.ts",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "keywords": [
    "electron",
    "docker",
    "react",
    "typescript"
  ],
  "author": "OpenAI Codex",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=11"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@uiw/react-codemirror": "^4.25.11",
    "@xyflow/react": "latest",
    "d3-force": "^3.0.0",
    "dockerode": "^5.0.1",
    "electron-squirrel-startup": "latest",
    "elkjs": "latest",
    "fast-xml-parser": "4.5.7",
    "lucide-react": "^1.23.0",
    "react": "latest",
    "react-dom": "latest",
    "tsx": "^4.23.0",
    "write-file-atomic": "^7.0.0",
    "yaml": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@electron-forge/cli": "latest",
    "@electron-forge/maker-deb": "latest",
    "@electron-forge/maker-rpm": "latest",
    "@electron-forge/maker-squirrel": "latest",
    "@electron-forge/maker-zip": "latest",
    "@electron-forge/plugin-webpack": "latest",
    "@electron-forge/shared-types": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/dockerode": "^4.0.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "css-loader": "latest",
    "electron": "latest",
    "jsdom": "latest",
    "png-to-ico": "^3.0.2",
    "style-loader": "latest",
    "ts-loader": "latest",
    "typescript": "^5.9.2",
    "vitest": "latest"
  },
  "overrides": {
    "tldts": "7.4.6",
    "tldts-core": "7.4.6",
    "shell-quote": "1.9.0",
    "prettier": "3.9.4",
    "bonjour-service": "1.4.2"
  }
}
